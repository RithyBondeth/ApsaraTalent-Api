# ==============================================
# APSARA TALENT API - PRODUCTION ENVIRONMENT
# ==============================================
# Copy these values into Railway's environment variables per service.
# All services share the same set of env vars in a Railway project.

# --------------------
# NODE ENVIRONMENT
# --------------------
NODE_ENV=production

# --------------------
# DATABASE (Neon PostgreSQL)
# --------------------
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_SYNCHRONIZE=false

# --------------------
# JWT CONFIG
# --------------------
JWT_SECRET=
JWT_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d
JWT_EMAIL_EXPIRES=24h

# --------------------
# SESSION CONFIG
# --------------------
SESSION_SECRET=

# --------------------
# EMAIL (SMTP)
# --------------------
SMTP_HOST=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# --------------------
# RATE LIMIT / THROTTLER
# --------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --------------------
# SMS (TWILIO)
# --------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --------------------
# MICROSERVICES (Railway private networking)
# Each service is reachable internally by its Railway service name.
# Replace the hostnames below with the actual service names you create in Railway.
# --------------------
API_GATEWAY_PORT=3000

AUTH_SERVICE_HOST=auth-service.railway.internal
AUTH_SERVICE_PORT=3001

USER_SERVICE_HOST=user-service.railway.internal
USER_SERVICE_PORT=3002

RESUME_SERVICE_HOST=resume-builder-service.railway.internal
RESUME_SERVICE_PORT=3003

CHAT_SERVICE_HOST=chat-service.railway.internal
CHAT_SERVICE_PORT=3004

JOB_SERVICE_HOST=job-service.railway.internal
JOB_SERVICE_PORT=3005

PAYMENT_SERVICE_HOST=payment-service.railway.internal
PAYMENT_SERVICE_PORT=3006

NOTIFICATION_SERVICE_HOST=notification-service.railway.internal
NOTIFICATION_SERVICE_PORT=3007

# --------------------
# REDIS (Railway Redis add-ons)
# Add two Redis instances in Railway: one for WebSocket, one for caching.
# Replace hostnames with the actual Redis service names in Railway.
# --------------------
REDIS_WEBSOCKET_HOST=redis-websocket.railway.internal
REDIS_WEBSOCKET_PORT=6379

REDIS_CACHING_HOST=redis-caching.railway.internal
REDIS_CACHING_PORT=6379
REDIS_CACHING_USER=
REDIS_CACHING_PASSWORD=
REDIS_CACHING_TLS=false
REDIS_CACHING_TTL=300

# --------------------
# FRONTEND
# --------------------
FRONTEND_ORIGIN=https://your-app.vercel.app

# --------------------
# BASE URL (public api-gateway URL from Railway)
# Used for OAuth callback URLs and email links.
# Do NOT include /api suffix here - this is the raw gateway URL.
# --------------------
BASE_URL=https://your-api-gateway.railway.app

# --------------------
# SOCIAL AUTH
# --------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api-gateway.railway.app/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://your-api-gateway.railway.app/auth/linkedin/callback
LINKEDIN_PROFILE_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-api-gateway.railway.app/auth/github/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://your-api-gateway.railway.app/auth/facebook/callback

# --------------------
# OPENAI
# --------------------
OPENAI_API_KEY=

# --------------------
# FIREBASE (PUSH NOTIFICATIONS)
# --------------------
FIREBASE_SERVICE_ACCOUNT=

# --------------------
# BAKONG KHQR PAYMENT
# --------------------
BAKONG_DEVELOPER_TOKEN=
BAKONG_API_BASE_URL=https://api-bakong.nbc.gov.kh
BAKONG_API_TIMEOUT=30000
BAKONG_RATE_LIMIT_REQUESTS=100
BAKONG_RATE_LIMIT_WINDOW_MS=60000
BAKONG_QR_IMAGE_DEFAULT_WIDTH=300
BAKONG_QR_IMAGE_MAX_WIDTH=1000
BAKONG_QR_EXPIRATION_MAX_MINUTES=10080
BAKONG_BULK_PAYMENT_MAX_HASHES=50
